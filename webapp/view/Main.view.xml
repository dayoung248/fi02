<mvc:View xmlns:core="sap.ui.core" controllerName="code.t4.ui5.fi02.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

    <Page id="page" title="[FI] 수익성분석">

        <IconTabBar
            id="idIconTabBar"
            select=".onTabSelect"
            class="sapUiResponsiveContentPadding">

            <items>
                <IconTabFilter
                    text="전체"
                    key="A"
                    icon="sap-icon://vertical-waterfall-chart" />

                <IconTabFilter
                    text="일반판매"
                    key="G"
                    icon="sap-icon://sales-order" />

                <IconTabFilter
                    text="렌탈판매"
                    key="R"
                    icon="sap-icon://line-chart-time-axis" />
            </items>

            <content>
                <HBox >
                    <Label text="비교 기준" class="sapUiSmallMarginEnd"/>
                    <Select
                        id="idPeriodType"
                        selectedKey="M"
                        change=".onPeriodTypeChange" >
                        <items>
                            <core:Item key="M" text="월 기준"/>
                            <core:Item key="W" text="주 기준"/>
                        </items>
                    </Select>
                    <Select
                        id="idMonat"
                        selectedKey="05"
                        change=".onMonatChange" >
                    </Select>
                    <Select
                        id="idWeeks"
                        selectedKey="00"
                        change=".onPeriodChange" >
                    </Select>
                    <Input
                        id="idCompPeriodText"
                        editable="false"
                        width="16rem"
                        class="sapUiTinyMarginBegin"/>
                </HBox>
                <HBox
                    id="kpiBox"
                    width="100%"
                    wrap="NoWrap"
                    justifyContent="Center"
                    class="sapUiSmallMarginTopBottom">
                    <VBox class="sapUiTinyMarginBegin sapUiSmallMarginEnd">
                        <GenericTile
                            id="idSalesTile"
                            header="당기매출"
                            subheader="비교기간 대비"
                            width="18rem"
                            frameType="TwoByOne">
                            <TileContent unit="" footer="">
                            <VBox>
                                <NumericContent
                                    value="{ parts: [ 'Salesamt',
                                                      'Waers' ],
                                                      type: 'sap.ui.model.type.Currency',
                                                      formatOptions: { showMeasure: false } }"
                                    scale="{Waers}"
                                    valueColor="{= ${Prevsalesrate} >= 0 ? 'Good' : 'Error' }"
                                    indicator="{= ${Prevsalesrate} > 0 ? 'Up' : ${Prevsalesrate} &lt; 0 ? 'Down' : 'None' }"
                                    truncateValueTo="12"
                                    withMargin="false" /> 

                                <ObjectStatus
                                    text="{= ${Compsalesamt} === '0.000' ? '비교기간 매출 없음' : '비교기간 대비 ' + ${Prevsalesrate} + '%' }"
                                    state="{= ${Compsalesamt} === '0.000' ? 'None' : ${Prevsalesrate} >= 0 ? 'Success' : 'Error' }"/>
                            </VBox>
                                <!-- value="{ parts: [ 'Salesamt',
                                    'Waers' ],
                                    type: 'sap.ui.model.type.Currency',
                                    formatOptions: { showMeasure: false } }"
                                    scale="{Waers}"
                                    valueColor="Good"
                                    indicator="Up"
                                    truncateValueTo="12"
                                    withMargin="false" 
                                    width="100%"/> -->
                            </TileContent>
                        </GenericTile>
                    </VBox>

                    <VBox class="sapUiSmallMarginEnd">
                        <GenericTile
                            header="당기원가"
                            subheader="비교기간 대비"
                            width="18rem"
                            frameType="TwoByOne">
                            <TileContent footer="">
                            <VBox>
                                <NumericContent
                                    value="{ parts: [ 'Costamt',
                                                      'Waers' ],
                                                      type: 'sap.ui.model.type.Currency',
                                                      formatOptions: { showMeasure: false } }"
                                    scale="{Waers}"
                                    valueColor="{= ${Prevcostrate} >= 0 ? 'Error' : 'Good' }"
                                    indicator="{= ${Prevcostrate} > 0 ? 'Up' : ${Prevcostrate} &lt; 0 ? 'Down' : 'None' }"
                                    truncateValueTo="12"
                                    withMargin="false" 
                                    width="100%"/>
                                <ObjectStatus
                                    text="{= ${Compcostamt} === '0.000' ? '비교기간 원가 없음' : '비교기간 대비 ' + ${Prevcostrate} + '%' }"
                                    state="{= ${Compcostamt} === '0.000' ? 'None' : ${Prevcostrate} >= 0 ? 'Error' : 'Success' }"/>
                            </VBox>
                            </TileContent>
                        </GenericTile>
                    </VBox>

                    <VBox class="sapUiSmallMarginEnd">
                        <GenericTile
                            header="당기이익"
                            subheader="비교기간 대비"
                            width="18rem"
                            frameType="TwoByOne">
                            <TileContent unit="" footer="">
                                <VBox>
                                <NumericContent
                                    value="{ parts: [ 'Profitamt',
                                                      'Waers' ],
                                                      type: 'sap.ui.model.type.Currency',
                                                      formatOptions: { showMeasure: false } }"
                                    scale="{Waers}"
                                    valueColor="{= ${Prevprofitrate} >= 0 ? 'Good' : 'Error' }"
                                    indicator="{= ${Prevprofitrate} > 0 ? 'Up' : ${Prevprofitrate} &lt; 0 ? 'Down' : 'None' }"
                                    truncateValueTo="12"
                                    withMargin="false" 
                                    width="100%"/>
                                <ObjectStatus
                                    text="{= ${Compprofitamt} === '0.000' ? '비교기간 이익 없음' : '비교기간 대비 ' + ${Prevprofitrate} + '%' }"
                                    state="{= ${Compprofitamt} === '0.000' ? 'None' : ${Prevprofitrate} >= 0 ? 'Success' : 'Error' }"/>
                                </VBox>
                            </TileContent>
                        </GenericTile>
                    </VBox>

                    <VBox class="sapUiSmallMarginEnd">
                        <GenericTile
                            header="이익률"
                            subheader="비교기간 대비"
                            width="18rem"
                            frameType="TwoByOne">
                            <!--valueColor="Good"
                                    indicator="None"-->
                            
                            <TileContent > <!--unit="%" footer="당기 기준">-->
                                <VBox>
                                    <NumericContent
                                        value="{Profitrate}"
                                        scale="%"
                                        valueColor="{= ${Compprofitrate} >= 0 ? 'Good' : 'Error' }"
                                        indicator="{= ${Compprofitrate} > 0 ? 'Up' : ${Compprofitrate} &lt; 0 ? 'Down' : 'None' }"
                                        truncateValueTo="8"
                                        withMargin="false" 
                                        width="100%"/>
                                    <!--ObjectStatus
                                        text="{= ${Compsalesamt} === '0.000' && ${Compcostamt} !== '0.000'
                                                ? '비교기간 매출 미발생'
                                                : ${Compsalesamt} === '0.000'
                                                    ? '비교기준 없음'
                                                    : '비교기간 대비 ' + ${Compprofitrate} + '%p' }"
                                            state="{= ${Compsalesamt} === '0.000'
                                                ? 'None'
                                                : ${Compprofitrate} > 0
                                                    ? 'Success'
                                                    : ${Compprofitrate} &lt; 0
                                                        ? 'Error'
                                                        : 'None' }"/-->
                                    <ObjectStatus
                                        text="{= ${Compsalesamt} === '0.000' &amp;&amp; ${Compcostamt} !== '0.000' ? '비교기간 매출 미발생' : ${Compsalesamt} === '0.000' ? '비교기준 없음' : '비교기간 대비 ' + ${Compprofitrate} + '%p' }"
                                        state="{= ${Compsalesamt} === '0.000' ? 'None' : ${Compprofitrate} > 0 ? 'Success' : ${Compprofitrate} &lt; 0 ? 'Error' : 'None' }"/>
                                </VBox>
                            </TileContent>
                            
                        </GenericTile>
                    </VBox>
                </HBox>
                <VBox
                    id="idDetailBox"
                    visible="false"
                    width="100%" 
                    class="sapUiSmallMarginTop">

                    <SegmentedButton
                        id="idAnalysisSegment"
                        selectedKey="C"
                        selectionChange=".onAnalysisSegmentChange"
                        class="sapUiTinyMarginBottom">
                        <items>
                            <SegmentedButtonItem key="C" text="고객유형별"/>
                            <SegmentedButtonItem key="M" text="제품별"/>
                        </items>
                    </SegmentedButton>

                    <Title
                        id="idDetailTitle"
                        text="상세 수익성 분석"
                        level="H4"
                        class="sapUiTinyMarginBottom"/>

                    <Table
                        id="idDetailTable"
                        width="100%"
                        items="{detail>/detailData}"
                        class="sapUiTinyMarginBottom">

                        <columns>
                            <Column><Text id="idDimensionColumnText" text="고객유형"/></Column>
                            <Column hAlign="End"><Text text="매출"/></Column>
                            <Column hAlign="End"><Text text="원가"/></Column>
                            <Column hAlign="End"><Text text="이익"/></Column>
                            <Column hAlign="End"><Text text="이익률"/></Column>
                        </columns>

                        <items>
                            <ColumnListItem>
                                <cells>
                                <!--number="{detail>Revenue}"-->
                                    <Text text="{detail>Dimension}"/>
                                    <ObjectNumber
                                        number="{ parts: [ 'detail>Revenue',
                                                           'detail>Waers' ],
                                                  type: 'sap.ui.model.type.Currency',
                                                  formatOptions: { showMeasure: false } }"
                                        unit="{detail>Waers}"/>
                                    
                                    <ObjectNumber
                                        number="{ parts: [ 'detail>Cost',
                                                           'detail>Waers' ],
                                                  type: 'sap.ui.model.type.Currency',
                                                  formatOptions: { showMeasure: false } }"
                                        unit="{detail>Waers}"/>
                                    <ObjectNumber 
                                        number="{ parts: [ 'detail>Profit',
                                                           'detail>Waers' ],
                                                  type: 'sap.ui.model.type.Currency',
                                                  formatOptions: { showMeasure: false } }"
                                        unit="{detail>Waers}"/>
                                    <ObjectNumber
                                        number="{detail>Profitrate}"
                                        unit="%"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                    <VBox
                        id="idDetailChartBox"
                        width="100%"
                        class="sapUiSmallMarginTop">

                        <viz:VizFrame
                            id="idDetailBarChart"
                            width="100%"
                            height="22rem"
                            vizType="column"
                            class="sapUiSmallMarginBottom">

                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{detail>/detailChartData}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition
                                            name="분석대상"
                                            value="{detail>Dimension}" />
                                    </viz.data:dimensions>

                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition
                                            name="매출"
                                            value="{detail>Revenue}" />
                                        <viz.data:MeasureDefinition
                                            name="원가"
                                            value="{detail>Cost}" />
                                        <viz.data:MeasureDefinition
                                            name="이익"
                                            value="{detail>Profit}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>

                            <viz:feeds>
                                <viz.feeds:FeedItem
                                    uid="valueAxis"
                                    type="Measure"
                                    values="매출,원가" />
                                <viz.feeds:FeedItem
                                    uid="categoryAxis"
                                    type="Dimension"
                                    values="분석대상" />
                            </viz:feeds>
                        </viz:VizFrame>

                        <viz:VizFrame
                            id="idDetailDonutChart"
                            width="100%"
                            height="20rem"
                            vizType="donut">

                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{detail>/detailDonutData}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition
                                            name="분석대상"
                                            value="{detail>Dimension}" />
                                    </viz.data:dimensions>

                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition
                                            name="매출비중"
                                            value="{detail>Revenue}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>

                            <viz:feeds>
                                <viz.feeds:FeedItem
                                    uid="size"
                                    type="Measure"
                                    values="매출비중" />
                                <viz.feeds:FeedItem
                                    uid="color"
                                    type="Dimension"
                                    values="분석대상" />
                            </viz:feeds>
                        </viz:VizFrame>

                    </VBox>

                </VBox>
                <viz:VizFrame
                    id="idSalesCompareChart"
                    width="100%"
                    height="20rem"
                    vizType="column"
                    vizProperties="{
                        'title': {
                            'visible': true,
                            'text': '일반판매 vs 렌탈판매 매출 비교'
                        }
                    }">

                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{chart>/salesCompare}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition
                                    name="기간"
                                    value="{chart>Period}" />

                                <viz.data:DimensionDefinition
                                    name="판매유형"
                                    value="{chart>SalesTypeText}" />
                            </viz.data:dimensions>

                            <viz.data:measures>
                                <viz.data:MeasureDefinition
                                    name="매출"
                                    value="{chart>Sales}" />
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>

                    <viz:feeds>
                        <viz.feeds:FeedItem
                            uid="valueAxis"
                            type="Measure"
                            values="매출" />

                        <viz.feeds:FeedItem
                            uid="categoryAxis"
                            type="Dimension"
                            values="기간" />

                        <viz.feeds:FeedItem
                            uid="color"
                            type="Dimension"
                            values="판매유형" />
                    </viz:feeds>
                </viz:VizFrame>
            </content>
        </IconTabBar>
    </Page>
</mvc:View>
                    