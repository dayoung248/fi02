<mvc:View xmlns:core="sap.ui.core" controllerName="code.t4.ui5.fi02.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

    
    <Page id="page" title="[FI] 수익성분석">

        <IconTabBar
            id="idIconTabBar"
            select=".onTabSelect"
            class="sapUiResponsiveContentPadding">
            
                <items>
                    <IconTabFilter
                        text="전체"
                        key="A"
                        icon="sap-icon://vertical-waterfall-chart" />

                    <IconTabFilter
                        text="일반판매"
                        key="G"
                        icon="sap-icon://sales-order" />

                    <IconTabFilter
                        text="렌탈판매"
                        key="R"
                        icon="sap-icon://line-chart-time-axis" />
                </items>

                <content>
            
                    <HBox >
                        <Label text="비교 기준" class="sapUiTinyMarginEnd sapUiTinyMarginTop"/>
                        <Select
                            id="idPeriodType"
                            selectedKey="M"
                            change=".onPeriodTypeChange" 
                            class="sapUiTinyMarginEnd sapUiTinyMarginTop">
                            <items>
                                <core:Item key="M" text="월 기준"/>
                                <core:Item key="W" text="주 기준"/>
                            </items>
                        </Select>
                        <Select
                            id="idMonat"
                            selectedKey="05"
                            change=".onMonatChange"
                            class="sapUiTinyMarginEnd sapUiTinyMarginTop" >
                        </Select>
                        <Select
                            id="idWeeks"
                            selectedKey="00"
                            width="18rem"
                            visible="false"
                            change=".onPeriodChange"
                            class="sapUiTinyMarginEnd sapUiTinyMarginTop" >
                        </Select>
                    </HBox>
                    
                    <HBox
                        id="kpiBox"
                        width="100%"
                        wrap="NoWrap"
                        justifyContent="Center"
                        class="sapUiSmallMarginTopBottom">
                        <VBox class="sapUiTinyMarginBegin sapUiSmallMarginEnd">
                            <GenericTile
                                id="idSalesTile"
                                header="당기매출(단위: 원)"
                                
                                width="18rem"
                                frameType="TwoByOne">
                                <TileContent unit="" footer="">
                                    <VBox>
                                        <NumericContent
                                            id="idSalesNumeric"
                                            value="{ parts: [ 'Salesamt',
                                                            'Waers' ],
                                                            type: 'sap.ui.model.type.Currency',
                                                            formatOptions: { showMeasure: false } }"
                                            scale=""
                                            valueColor="{= ${Prevsalesrate} >= 0 ? 'Good' : 'Error' }"
                                            indicator="None"
                                            truncateValueTo="16"
                                            withMargin="false"
                                            width="100%" /> 

                                        <ObjectStatus
                                            id="idSalesKpiStatus"
                                            text="{= ${Compsalesamt} === 0 || ${Compsalesamt} === '0' || ${Compsalesamt} === '0.000' ? '비교기간 매출 없음' : '비교기간 대비 ' + ${Prevsalesrate} + '%' }"
                                            state="{= ${Compsalesamt} === 0 || ${Compsalesamt} === '0' || ${Compsalesamt} === '0.000' ? 'None' : ${Prevsalesrate} >= 0 ? 'Success' : 'Error' }"/>
                                    </VBox>
                                    <!-- value="{ parts: [ 'Salesamt',
                                        'Waers' ],
                                        type: 'sap.ui.model.type.Currency',
                                        formatOptions: { showMeasure: false } }"
                                        scale="{Waers}"
                                        valueColor="Good"
                                        indicator="Up"
                                        truncateValueTo="12"
                                        withMargin="false" 
                                        width="100%"/> -->
                                </TileContent>
                            </GenericTile>
                        </VBox>

                        <VBox class="sapUiSmallMarginEnd">
                            <GenericTile
                                header="당기원가(단위: 원)"

                                width="18rem"
                                frameType="TwoByOne">
                                <TileContent footer="">
                                    <VBox>
                                        <NumericContent
                                            id="idCostNumeric"
                                            value="{ parts: [ 'Costamt',
                                                            'Waers' ],
                                                            type: 'sap.ui.model.type.Currency',
                                                            formatOptions: { showMeasure: false } }"
                                            scale=""
                                            valueColor="{= ${Prevcostrate} >= 0 ? 'Error' : 'Good' }"
                                            indicator="None"
                                            truncateValueTo="16"
                                            withMargin="false" 
                                            width="100%"/>
                                        <ObjectStatus
                                            id="idCostKpiStatus"
                                            text="{= ${Compcostamt} === 0 || ${Compcostamt} === '0' || ${Compcostamt} === '0.000' ? '비교기간 원가 없음' : '비교기간 대비 ' + ${Prevcostrate} + '%' }"
                                            state="{= ${Compcostamt} === 0 || ${Compcostamt} === '0' || ${Compcostamt} === '0.000' ? 'None' : ${Prevcostrate} >= 0 ? 'Error' : 'Success' }"/>
                                    </VBox>
                                </TileContent>
                            </GenericTile>
                        </VBox>

                        <VBox class="sapUiSmallMarginEnd">
                            <GenericTile
                                header="당기이익(단위: 원)"
                                
                                width="18rem"
                                frameType="TwoByOne">
                                <TileContent unit="" footer="">
                                    <VBox>
                                        <NumericContent
                                            id="idProfitNumeric"
                                            value="{ parts: [ 'Profitamt',
                                                            'Waers' ],
                                                            type: 'sap.ui.model.type.Currency',
                                                            formatOptions: { showMeasure: false } }"
                                            scale=""
                                            valueColor="{= ${Prevprofitrate} >= 0 ? 'Good' : 'Error' }"
                                            indicator="None"
                                            truncateValueTo="16"
                                            withMargin="false" 
                                            width="100%"/>
                                        <ObjectStatus
                                            id="idProfitKpiStatus"
                                            text="{= ${Compprofitamt} === 0 || ${Compprofitamt} === '0' || ${Compprofitamt} === '0.000' ? '비교기간 이익 없음' : '비교기간 대비 ' + ${Prevprofitrate} + '%' }"
                                            state="{= ${Compprofitamt} === 0 || ${Compprofitamt} === '0' || ${Compprofitamt} === '0.000' ? 'None' : ${Prevprofitrate} >= 0 ? 'Success' : 'Error' }"/>
                                    </VBox>
                                </TileContent>
                            </GenericTile>
                        </VBox>

                        <VBox class="sapUiSmallMarginEnd">
                            <GenericTile
                                header="이익률(단위: %)"
                                
                                width="18rem"
                                frameType="TwoByOne">
                                <!--valueColor="Good"
                                        indicator="None"-->
                                
                                <TileContent > <!--unit="%" footer="당기 기준">-->
                                    <VBox>
                                        <NumericContent
                                            id="idProfitRateNumeric"
                                            value="{Profitrate}"
                                            scale="%"
                                            valueColor="{= ${Compprofitrate} >= 0 ? 'Good' : 'Error' }"
                                            indicator="None"
                                            truncateValueTo="8"
                                            withMargin="false" 
                                            width="100%"/>
                                        <ObjectStatus
                                            id="idProfitRateKpiStatus"
                                            text="{= (${Compsalesamt} === 0 || ${Compsalesamt} === '0' || ${Compsalesamt} === '0.000') &amp;&amp; ${Compcostamt} !== 0 &amp;&amp; ${Compcostamt} !== '0' &amp;&amp; ${Compcostamt} !== '0.000' ? '비교기간 매출 미발생' : ${Compsalesamt} === 0 || ${Compsalesamt} === '0' || ${Compsalesamt} === '0.000' ? '비교기준 없음' : '비교기간 대비 ' + ${Compprofitrate} + '%p' }"
                                            state="{= ${Compsalesamt} === 0 || ${Compsalesamt} === '0' || ${Compsalesamt} === '0.000' ? 'None' : ${Compprofitrate} > 0 ? 'Success' : ${Compprofitrate} &lt; 0 ? 'Error' : 'None' }"/>
                                    </VBox>
                                </TileContent>
                                
                            </GenericTile>
                        </VBox>
                    </HBox>

                    <viz:VizFrame
                            id="idSalesCompareChart"
                            width="100%"
                            height="20rem"
                            vizType="column"
                            vizProperties="{
                                'title': {
                                    'visible': true,
                                    'text': '일반판매 vs 렌탈판매 매출/원가/이익 비교'
                                }
                            }">

                        <viz:dataset>
                            <viz.data:FlattenedDataset data="{chart>/salesCompare}">
                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition
                                        name="기간"
                                        value="{chart>Period}" />

                                    <viz.data:DimensionDefinition
                                        name="판매유형"
                                        value="{chart>SalesTypeText}" />

                                    <viz.data:DimensionDefinition
                                        name="항목"
                                        value="{chart>Metric}" />
                                </viz.data:dimensions>

                                <viz.data:measures>
                                    <viz.data:MeasureDefinition
                                        name="금액"
                                        value="{chart>Amount}" />
                                </viz.data:measures>
                            </viz.data:FlattenedDataset>
                        </viz:dataset>

                        <viz:feeds>
                            <viz.feeds:FeedItem
                                uid="valueAxis"
                                type="Measure"
                                values="금액" />

                            <viz.feeds:FeedItem
                                uid="categoryAxis"
                                type="Dimension"
                                values="기간,판매유형" />

                            <viz.feeds:FeedItem
                                uid="color"
                                type="Dimension"
                                values="항목" />
                        </viz:feeds>
                    </viz:VizFrame>
                
                <VBox
                    id="idDetailBox"
                    visible="false"
                    height="50rem"
                    width="100%" 
                    class="sapUiSmallMarginTop">

                    <SegmentedButton
                                id="idAnalysisSegment"
                                selectedKey="C"
                                selectionChange=".onAnalysisSegmentChange"
                                class="sapUiTinyMarginBottom">
                        <items>
                            <SegmentedButtonItem key="C" text="고객유형별"/>
                            <SegmentedButtonItem key="M" text="제품별"/>
                        </items>
                    </SegmentedButton>

                    <Title
                        id="idDetailTitle"
                        text="상세 수익성 분석"
                        level="H4"
                        class="sapUiTinyMarginBottom"/>
                    <f:FlexibleColumnLayout 
                        id="idFCL"
                        layout="OneColumn" >
                        <f:layoutData>
                            <FlexItemData growFactor="1" />
                        </f:layoutData>

                        <f:beginColumnPages>
                            <Page showHeader="false" >
                                <content>
                                    <VBox >
                                    <Table
                                        id="idDetailTable"
                                        width="100%"
                                        items="{detail>/detailData}"
                                        class="sapUiTinyMarginBottom"
                                        mode="SingleSelectMaster"
                                        selectionChange=".onDetailRowSelect">

                                        <columns>
                                            <Column id="idDimensionColumn" width="8rem">
                                                <Text id="idDimensionColumnText" text="고객유형" wrapping="false"/>
                                            </Column>
                                            <Column id="idRevenueColumn" width="4.8rem" hAlign="End"><Text text="매출" wrapping="false"/></Column>
                                            <Column id="idCostColumn" width="4.8rem" hAlign="End"><Text text="원가" wrapping="false"/></Column>
                                            <Column id="idProfitColumn" width="4.8rem" hAlign="End"><Text text="이익" wrapping="false"/></Column>
                                            <Column id="idProfitRateColumn" width="4.2rem" hAlign="End"><Text text="이익률" wrapping="false"/></Column>
                                        </columns>

                                        <items>
                                            <ColumnListItem type="Navigation">
                                                <cells>
                                                <!--number="{detail>Revenue}"-->
                                                    <VBox class="fi02DimensionCell">
                                                        <Text
                                                            text="{detail>Dimension}"
                                                            wrapping="false"
                                                            class="fi02DimensionCode"/>
                                                        <Text
                                                            text="{detail>DimensionTxt}"
                                                            wrapping="true"
                                                            visible="{= !!${detail>DimensionTxt} }"
                                                            class="fi02DimensionText"/>
                                                    </VBox>
                                                    <ObjectNumber
                                                        number="{ parts: [ 'detail>Revenue',
                                                                        'detail>Waers' ],
                                                                type: 'sap.ui.model.type.Currency',
                                                                formatOptions: { showMeasure: false } }"
                                                        unit="{detail>Waers}"/>
                                                    
                                                    <ObjectNumber
                                                        number="{ parts: [ 'detail>Cost',
                                                                        'detail>Waers' ],
                                                                type: 'sap.ui.model.type.Currency',
                                                                formatOptions: { showMeasure: false } }"
                                                        unit="{detail>Waers}"/>
                                                    <ObjectNumber 
                                                        number="{ parts: [ 'detail>Profit',
                                                                        'detail>Waers' ],
                                                                type: 'sap.ui.model.type.Currency',
                                                                formatOptions: { showMeasure: false } }"
                                                        unit="{detail>Waers}"/>
                                                    <ObjectNumber
                                                        number="{detail>Profitrate}"
                                                        unit="%"/>
                                                </cells>
                                            </ColumnListItem>
                                        </items>
                                    </Table>
                                    </VBox>
                                    <!--<VBox
                                        id="idDetailChartBox"
                                        width="100%"
                                        class="sapUiSmallMarginTop">-->

                                        <!--<viz:VizFrame
                                            id="idDetailBarChart"
                                            width="100%"
                                            height="22rem"
                                            vizType="column"
                                            class="sapUiSmallMarginBottom">

                                            <viz:dataset>
                                                <viz.data:FlattenedDataset data="{detail>/detailChartData}">
                                                    <viz.data:dimensions>
                                                        <viz.data:DimensionDefinition
                                                            name="분석대상"
                                                            value="{detail>Dimension}" />
                                                    </viz.data:dimensions>

                                                    <viz.data:measures>
                                                        <viz.data:MeasureDefinition
                                                            name="매출"
                                                            value="{detail>Revenue}" />
                                                        <viz.data:MeasureDefinition
                                                            name="원가"
                                                            value="{detail>Cost}" />
                                                        <viz.data:MeasureDefinition
                                                            name="이익"
                                                            value="{detail>Profit}" />
                                                    </viz.data:measures>
                                                </viz.data:FlattenedDataset>
                                            </viz:dataset>

                                            <viz:feeds>
                                                <viz.feeds:FeedItem
                                                    uid="valueAxis"
                                                    type="Measure"
                                                    values="매출,원가" />
                                                <viz.feeds:FeedItem
                                                    uid="categoryAxis"
                                                    type="Dimension"
                                                    values="분석대상" />
                                            </viz:feeds>
                                        </viz:VizFrame>-->

                                        <viz:VizFrame
                                            id="idDetailDonutChart"
                                            width="100%"
                                            height="20rem"
                                            vizType="donut"
                                            class="fi02DetailDonutChart">

                                            <viz:dataset>
                                                <viz.data:FlattenedDataset data="{detail>/detailDonutData}">
                                                    <viz.data:dimensions>
                                                        <viz.data:DimensionDefinition
                                                            name="분석대상"
                                                            value="{detail>Dimension}" />
                                                    </viz.data:dimensions>

                                                    <viz.data:measures>
                                                        <viz.data:MeasureDefinition
                                                            name="매출비중"
                                                            value="{detail>Revenue}" />
                                                    </viz.data:measures>
                                                </viz.data:FlattenedDataset>
                                            </viz:dataset>

                                            <viz:feeds>
                                                <viz.feeds:FeedItem
                                                    uid="size"
                                                    type="Measure"
                                                    values="매출비중" />
                                                <viz.feeds:FeedItem
                                                    uid="color"
                                                    type="Dimension"
                                                    values="분석대상" />
                                            </viz:feeds>
                                        </viz:VizFrame>
                                        <!--</VBox>-->
                                    </content>
                                </Page>
                            <!--</VBox>-->
                        </f:beginColumnPages>
                        <f:midColumnPages >
                            <Page
                                id="idSelectedDetailPage"
                                title="{selected>/title}"
                                showNavButton="true"
                                navButtonPress=".onCloseFlexibleDetail">

                                <VBox >
                                    <HBox wrap="Wrap" alignContent="Center" class="sapUiSmallMarginTopBottom" >
                                        <GenericTile header="매출(단위: 원)" class="sapUiTinyMarginBeginEnd fi02DetailKpiTile" frameType="OneByHalf">
                                            <TileContent footer="{selected>/RevenueCompareText}">
                                                <NumericContent
                                                    class="fi02DetailKpiNumber"
                                                    value="{ parts:['selected>/Revenue','selected>/Waers'], type:'sap.ui.model.type.Currency', formatOptions:{ showMeasure:false } }"
                                                    scale=""
                                                    truncateValueTo="16"
                                                    width="100%"/>
                                            </TileContent>
                                        </GenericTile>

                                        <GenericTile header="원가(단위: 원)" class="sapUiTinyMarginEnd fi02DetailKpiTile" frameType="OneByHalf">
                                            <TileContent footer="{selected>/CostCompareText}">
                                                <NumericContent
                                                    class="fi02DetailKpiNumber"
                                                    value="{ parts:['selected>/Cost','selected>/Waers'], type:'sap.ui.model.type.Currency', formatOptions:{ showMeasure:false } }"
                                                    scale=""
                                                    truncateValueTo="16"
                                                    width="100%"/>
                                            </TileContent>
                                        </GenericTile>

                                        <GenericTile header="이익(단위: 원)" class="sapUiTinyMarginEnd fi02DetailKpiTile" frameType="OneByHalf">
                                            <TileContent footer="{selected>/ProfitCompareText}">
                                                <NumericContent
                                                    class="fi02DetailKpiNumber"
                                                    value="{ parts:['selected>/Profit','selected>/Waers'], type:'sap.ui.model.type.Currency', formatOptions:{ showMeasure:false } }"
                                                    scale=""
                                                    truncateValueTo="16"
                                                    width="100%"
                                                    valueColor="{= ${selected>/Profit} >= 0 ? 'Good' : 'Error' }"/>
                                            </TileContent>
                                        </GenericTile>

                                        <GenericTile header="매출기여도" class="sapUiTinyMarginEnd" frameType="OneByHalf">
                                            <TileContent>
                                                <NumericContent
                                                    value="{selected>/ContributionRate}"
                                                    scale="%"
                                                    truncateValueTo="8"/>
                                            </TileContent>
                                        </GenericTile>
                                    </HBox>

                                    <HBox
                                        wrap="Wrap"
                                        alignItems="Center"
                                        class="sapUiTinyMarginBegin sapUiTinyMarginBottom">
                                        <CheckBox
                                            id="idTrendRevenueCheck"
                                            text="매출"
                                            selected="true"
                                            select=".onSelectedTrendOptionChange"/>
                                        <CheckBox
                                            id="idTrendCostCheck"
                                            text="원가"
                                            selected="true"
                                            select=".onSelectedTrendOptionChange"/>
                                        <CheckBox
                                            id="idTrendProfitCheck"
                                            text="이익"
                                            selected="true"
                                            select=".onSelectedTrendOptionChange"/>
                                        <CheckBox
                                            id="idTrendProfitRateCheck"
                                            text="이익률"
                                            selected="true"
                                            select=".onSelectedTrendOptionChange"/>
                                        <ToolbarSeparator class="sapUiSmallMarginBeginEnd"/>
                                        <Label text="레이블" class="sapUiTinyMarginEnd"/>
                                        <Switch
                                            id="idTrendLabelSwitch"
                                            state="true"
                                            customTextOn="ON"
                                            customTextOff="OFF"
                                            change=".onSelectedTrendOptionChange"/>
                                    </HBox>

                                    <viz:VizFrame
                                        id="idSelectedBarChart"
                                        width="100%"
                                        height="22rem"
                                        vizType="dual_combination">

                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{selected>/trendData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition
                                                        name="기간"
                                                        value="{selected>Periodlabel}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition
                                                        name="매출"
                                                        value="{selected>Revenue}" />
                                                    <viz.data:MeasureDefinition
                                                        name="원가"
                                                        value="{selected>Cost}" />
                                                    <viz.data:MeasureDefinition
                                                        name="이익"
                                                        value="{selected>Profit}" />
                                                    <viz.data:MeasureDefinition
                                                        name="이익률"
                                                        value="{selected>Profitrate}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                    </viz:VizFrame>
                                </VBox>
                            </Page>
                        </f:midColumnPages>
                    </f:FlexibleColumnLayout>
                </VBox>
            </content>
        </IconTabBar>
    </Page>
</mvc:View>
                    
